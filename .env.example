# DLP Backtester & Planner — variables de entorno (EJEMPLO)
# Copiá este archivo a .env (o usá .streamlit/secrets.toml) y completá con tus valores.
# NUNCA pongas claves reales acá — solo placeholders.

# Password gate de la app (si está vacío, la app corre en modo dev sin gate)
APP_PASSWORD=your-app-password-here

# Clave del LINK Fase 2 (el que se abre con ?fase2=1). El link normal NO pide clave.
# Si queda vacío, se usa el default del código (cámbialo por seguridad).
FASE2_PASSWORD=your-fase2-password-here

# Supabase (opcional en Fase 1 — si faltan, se usa persistencia local en .history/)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Anthropic (opcional — interpretación con IA en Fase 3)
ANTHROPIC_API_KEY=sk-ant-your-key-here
