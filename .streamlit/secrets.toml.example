# Copiá este archivo a .streamlit/secrets.toml y completá tus valores.
# .streamlit/secrets.toml está gitignored — NUNCA lo commitees.
# Si APP_PASSWORD queda vacío, la app corre en modo dev SIN gate.

APP_PASSWORD = "your-app-password-here"

# Clave del LINK Fase 2 (el que se abre con ?fase2=1). El link normal NO pide clave.
# Si queda sin definir, se usa el default del código (cámbialo por seguridad).
FASE2_PASSWORD = "your-fase2-password-here"

# Opcional — persistencia cloud. Si faltan, se usa .history/ local.
# SUPABASE_URL = "https://your-project.supabase.co"
# SUPABASE_SERVICE_KEY = "your-service-role-key-here"

# Opcional — interpretación con IA (Fase 3)
# ANTHROPIC_API_KEY = "sk-ant-your-key-here"
